{
	"name": "belte",
	"displayName": "BELTE",
	"description": "Language support for Belte",
	"version": "0.2.0",
	"publisher": "ryan_wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/ryanwilsond/belte"
	},
	"icon": "./images/BelteCapital.png",
	"engines": {
		"vscode": "^1.88.0"
	},
	"categories": [
		"Programming Languages"
	],
	"contributes": {
		"languages": [
			{
				"id": "belte",
				"aliases": [
					"Belte",
					"belte"
				],
				"extensions": [
					".blt",
					".belte"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"light": "./images/belte-icon128x.png",
					"dark": "./images/belte-icon128x.png"
				}
			},
            {
                "id": "belte-markdown-injection"
            }
		],
		"grammars": [
			{
				"language": "belte",
				"scopeName": "source.belte",
				"path": "./belte.tmLanguage.json"
			},
            {
                "language": "belte-markdown-injection",
                "scopeName": "markdown.belte.codeblock",
                "path": "./belte-markdown-injection.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.belte": "belte"
                }
            }
		],
        "breakpoints": [
            {
                "language": "belte"
            }
        ]
	},
	"__metadata": {
		"size": 312868
	}
}
