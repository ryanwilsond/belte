
class Program {
    Sprite cloud;
    Rect collision;

    public void Main() {
        Graphics.Initialize("Platformer", 1920, 1080);

        cloud = Graphics.LoadSprite("samples/Platformer/data/images/clouds/cloud_1.png", new Vec2(100, 100), null, 0);
        collision = new Rect(50, 50, 300, 50);

        // var grassTexture = Graphics.LoadTexture("samples/Assets/grass.jpg");
        // var playerSheet = Graphics.LoadTexture("samples/Assets/player_sheet.png");

        // for (int! y = 0; y < 7; y++) {
