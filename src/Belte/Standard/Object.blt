
class Object {
    protected constructor() { }

    public virtual string ToString() {
        return LowLevel.GetTypeName(this);
    }

    public virtual bool! Equals(Object object) {
        return this == object;
    }

    public bool! ReferenceEquals(Object object) {
        return this == object;
    }

    public virtual int! GetHashCode() {
        return LowLevel.GetHashCode(this);
    }
}
