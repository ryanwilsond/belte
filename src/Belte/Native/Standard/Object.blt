
public class Object {
    public constructor() { }

    finalizer() { }

    public virtual string? ToString() {
        return LowLevel.GetTypeName(this);
    }

    public virtual bool Equals(Object? object) {
        return object is null ? false : this == object!!;
    }

    public const bool ReferenceEquals(const Object? object) {
        return object is null ? false : this == object!!;
    }

    public virtual int32 GetHashCode() {
        return LowLevel.GetHashCode(this);
    }
}
