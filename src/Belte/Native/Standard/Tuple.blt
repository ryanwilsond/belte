    public override int32 GetHashCode() {
        return HashCode.Combine(Item1?.GetHashCode() ?? 0,
                                Item2?.GetHashCode() ?? 0,
                                Item3?.GetHashCode() ?? 0,
                                Item4?.GetHashCode() ?? 0,
                                Item5?.GetHashCode() ?? 0,
                                Item6?.GetHashCode() ?? 0);
