public struct ValueTuple<type T1, type T2, type T3, type T4, type T5, type T6> {
    public T1 Item1;
    public T2 Item2;
    public T3 Item3;
    public T4 Item4;
    public T5 Item5;
    public T6 Item6;

    public constructor(T1 item1, T2 item2, T3 item3, T4 item4, T5 item5, T6 item6) {
        Item1 = item1;
        Item2 = item2;
        Item3 = item3;
        Item4 = item4;
        Item5 = item5;
        Item6 = item6;
