
public struct ValueTuple<type T1> {
    public T1 Item1;

    public constructor(T1 item1) {
        Item1 = item1;
    }

    public override string? ToString() {
        return f"({Item1?.ToString()})";
    }

    public override bool Equals(Object object) {
        return object is ValueTuple<T1> tuple && Equals(tuple);
    }

    public bool Equals(ValueTuple<T1> other) {
        return EqualityComparer<T1>.Default.Equals(Item1, other.Item1);
    }

    public override int32 GetHashCode() {
        return Item1?.GetHashCode() ?? 0;
    }
}

public struct ValueTuple<type T1, type T2> {
    public T1 Item1;
    public T2 Item2;

    public constructor(T1 item1, T2 item2) {
        Item1 = item1;
        Item2 = item2;
    }

    public override string? ToString() {
        return f"({Item1?.ToString()}, {Item2?.ToString()})";
    }

    public override bool Equals(Object object) {
        return object is ValueTuple<T1, T2> tuple && Equals(tuple);
    }

    public bool Equals(ValueTuple<T1, T2> other) {
        return EqualityComparer<T1>.Default.Equals(Item1, other.Item1)
            && EqualityComparer<T2>.Default.Equals(Item2, other.Item2);
    }

    public override int32 GetHashCode() {
        return HashCode.Combine(Item1?.GetHashCode() ?? 0,
                                Item2?.GetHashCode() ?? 0);
    }
}

public struct ValueTuple<type T1, type T2, type T3> {
    public T1 Item1;
    public T2 Item2;
    public T3 Item3;

    public constructor(T1 item1, T2 item2, T3 item3) {
        Item1 = item1;
        Item2 = item2;
        Item3 = item3;
    }

    public override string? ToString() {
        return f"({Item1?.ToString()}, {Item2?.ToString()}, {Item3?.ToString()})";
    }

    public override bool Equals(Object object) {
        return object is ValueTuple<T1, T2, T3> tuple && Equals(tuple);
    }

    public bool Equals(ValueTuple<T1, T2, T3> other) {
        return EqualityComparer<T1>.Default.Equals(Item1, other.Item1)
            && EqualityComparer<T2>.Default.Equals(Item2, other.Item2)
            && EqualityComparer<T3>.Default.Equals(Item3, other.Item3);
    }

    public override int32 GetHashCode() {
        return HashCode.Combine(Item1?.GetHashCode() ?? 0,
                                Item2?.GetHashCode() ?? 0,
                                Item3?.GetHashCode() ?? 0);
    }
}

public struct ValueTuple<type T1, type T2, type T3, type T4> {
    public T1 Item1;
    public T2 Item2;
    public T3 Item3;
    public T4 Item4;

    public constructor(T1 item1, T2 item2, T3 item3, T4 item4) {
        Item1 = item1;
        Item2 = item2;
        Item3 = item3;
        Item4 = item4;
    }

    public override string? ToString() {
        return f"({Item1?.ToString()}, {Item2?.ToString()}, {Item3?.ToString()}, {Item4?.ToString()})";
    }

    public override bool Equals(Object object) {
        return object is ValueTuple<T1, T2, T3, T4> tuple && Equals(tuple);
    }

    public bool Equals(ValueTuple<T1, T2, T3, T4> other) {
        return EqualityComparer<T1>.Default.Equals(Item1, other.Item1)
            && EqualityComparer<T2>.Default.Equals(Item2, other.Item2)
            && EqualityComparer<T3>.Default.Equals(Item3, other.Item3)
            && EqualityComparer<T4>.Default.Equals(Item4, other.Item4);
    }

    public override int32 GetHashCode() {
        return HashCode.Combine(Item1?.GetHashCode() ?? 0,
                                Item2?.GetHashCode() ?? 0,
                                Item3?.GetHashCode() ?? 0,
                                Item4?.GetHashCode() ?? 0);
    }
}

